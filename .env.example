# Copy to .env and adjust (docker compose loads .env from the repo root):
#   cp .env.example .env
#
# Optional: only set both vars to bootstrap the first account without using the UI.
# Leave unset for a fresh ./data install — the app shows "Create account" on first visit.
# Docker Compose does not default a password; do not commit real secrets.

AUTH_USERNAME=admin
AUTH_PASSWORD=change-me-before-first-run
